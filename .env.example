# Supabase → Settings → API (copie exatamente do painel)
EXPO_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
# Chave publishable (recomendado) ou anon legacy
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Habilitar Google, Apple e Facebook em Supabase → Authentication → Providers
# Redirect: aetherion:// (scheme em app.json)

# Melhor Envio — Sandbox ou production (NUNCA prefixe segredos com EXPO_PUBLIC_)
MELHOR_ENVIO_ENV=sandbox
MELHOR_ENVIO_API_URL=https://sandbox.melhorenvio.com.br
MELHOR_ENVIO_CLIENT_ID=
MELHOR_ENVIO_CLIENT_SECRET=
MELHOR_ENVIO_ACCESS_TOKEN=
MELHOR_ENVIO_USER_AGENT=Levou Leiloes (seu-email@exemplo.com.br)
EXPO_PUBLIC_MELHOR_ENVIO_ENABLED=true

# Jarvis / IA (Supabase → Project Settings → Edge Functions → Secrets)
# OpenAI (recomendado se já usa): platform.openai.com
OPENAI_API_KEY=
# Ou Gemini: https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# AI_PROVIDER=openai
# Depois: npx supabase secrets set OPENAI_API_KEY=sua_chave
#         npx supabase functions deploy buyer-jarvis auction-ai-advisor listing-cover-ai
# Opcional remove fundo: REMOVE_BG_API_KEY= (https://www.remove.bg/api)

# supabase/migrations/046_wallet_demo_topup.sql

# Após deploy da Edge Function melhor-envio-quote, replique no Supabase Dashboard →
# Project Settings → Edge Functions → Secrets:
# MELHOR_ENVIO_API_URL, MELHOR_ENVIO_ACCESS_TOKEN, MELHOR_ENVIO_USER_AGENT

# Push notifications (Expo)
# Crie o projeto em https://expo.dev e copie o Project ID
EXPO_PUBLIC_EAS_PROJECT_ID=

# URL pública do app (web / links compartilhados)
EXPO_PUBLIC_APP_URL=https://levou.app.br

# Após deploy da Edge Function send-push, configure no Supabase → Edge Functions → Secrets:
# PUSH_CRON_SECRET=um-segredo-longo-aleatorio
# Agende cron (Dashboard → Integrations → Cron) POST /functions/v1/send-push
# Header: x-cron-secret: <PUSH_CRON_SECRET> a cada 1–2 minutos
# Migration: supabase/migrations/052_push_notifications.sql
